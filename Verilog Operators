module Relational_Operators();
reg [7:0] data1;
 reg [7:0] data2;

 initial begin
 data1 = 2'bxx;
 data2 = 2'b11;
   $display ("Result for data1 >= data2 : %b", data1 >= data2); 
   
data1 = 2'bzz;
 data2 = 2'b11;
   $display ("Result for data1 >= data2 : %b", data1 >= data2);  

 data1 = 4;
 data2 = 4;
 $display ("Result for data1 <= data2 : %0d", data1 <= data2); 

 data1 = 24;
 data2 = 5;
 $display ("Result for data1 > data2 : %0d", data1 > data2);
 data1 = 22;
 data2 = 24;
 $display ("Result for data1 < data2 : %0d", data1 < data2); 
 end
endmodule

