//.......Reduction operators...........
module Reduction_operators();
  reg [11:0]a=12'b000111xxxzzz;
  initial begin
    $display("Result of %b is : %0b ", a , &a );
    $display("Result of %b is : %0b ", a , |a );
    $display("Result of %b is : %0b ", a , ~a );
    $display("Result of %b is : %0b ", a , ~&a );
    $display("Result of %b is : %0b ", a , ~|a );
    $display("Result of %b is : %0b ", a , ^a );
    $display("Result of %b is : %0b ", a , ~^a );
  end
endmodule
