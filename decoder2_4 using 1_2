module decoder1_2(input in,en,output [1:0]y);
  assign y=en?1<<in:0;
endmodule

module decoder2_4(input [1:0]in,output [3:0]y);
  wire [1:0]w;
  decoder1_2 d1(in[1],1,w);
  decoder1_2 d2(in[0],w[0],y[1:0]);
  decoder1_2 d3(in[0],w[1],y[3:2]);
endmodule

module tb;
  reg [1:0]a;
  wire [3:0]y;
  decoder2_4 dut (a,y);
  integer i;
  initial begin
    $monitor("Time=%0t a=%b | y=%b",$time,a,y);
    for(i=0;i<4;i=i+1)
      begin
        a=i;
        #1;
      end
    $finish;
  end
endmodule
