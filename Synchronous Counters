module tb;
  parameter N=4;
  reg clk,rst,up_down;
  wire [N-1:0]q;
  sync_updown dut (clk,rst,up_down,q);
  initial clk=1;
  always #5 clk=~clk;
  initial begin
    $dumpfile("sync_up.vcd");
    $dumpvars(1,tb);
    $monitor("Time=%0t clk=%0b rst=%0b up_down=%0b| q=%d",$time,clk,rst,up_down,q);
    rst=1;
    #10
    rst=0;up_down=1;
    #((2**N)*10)
    rst=0;up_down=0;
    #((2**N)*10)
    $finish;
  end
endmodule
