module sync_updown #(parameter N=4)(input clk,rst,up_down,output reg [N-1:0]q);
  always @ (posedge clk)
    begin
      if(rst)
        q<=0;
      else if(up_down)
        q<=q+1;
      else
        q<=q-1;
    end 
endmodule

